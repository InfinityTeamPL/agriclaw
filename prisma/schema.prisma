// AgriClaw — schema zbudowana na wzorcu clawlabspro
// Różnice: Farm (zamiast Tenant), Field (z PostGIS geometry), NdviReading, Recommendation
// Utrzymane: Agent, InstalledSkill, Conversation, Message, Event, Usage, Task — bo każdy rolnik dostaje własnego agenta identycznie jak w clawlabspro

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DATABASE_URL_UNPOOLED")
  extensions = [postgis]
}

// -----------------------------
// Users + Auth (wzorzec clawlabspro)
// -----------------------------

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String?
  name          String?
  phoneNumber   String?  @unique @map("phone_number") // dla WhatsApp identyfikacji
  emailVerified Boolean  @default(false) @map("email_verified")
  avatarUrl     String?  @map("avatar_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  farms              Farm[]
  verificationTokens VerificationToken[]

  @@map("users")
}

model VerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("verification_tokens")
}

// -----------------------------
// Farm — odpowiednik Tenant z clawlabspro
// -----------------------------

model Farm {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String // "Gospodarstwo Kowalski"
  address   String
  lat       Float
  lon       Float
  apiKey    String   @unique @map("api_key") // do zewnętrznych integracji
  plan      String   @default("free") // free, standard, premium
  suspended Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  fields        Field[]
  agents        Agent[]
  conversations Conversation[]
  events        Event[]
  tasks         Task[]
  usage         Usage[]

  @@index([userId])
  @@map("farms")
}

// -----------------------------
// Field — pole z PostGIS polygon
// -----------------------------

model Field {
  id           String                                 @id @default(uuid())
  farmId       String                                 @map("farm_id")
  name         String // "Pole za stodołą"
  // PostGIS POLYGON 4326 — polygon rysowany przez rolnika na mapie
  polygon      Unsupported("geometry(Polygon, 4326)")
  crop         String // wheat, corn, rapeseed, barley, potato, other
  areaHectares Float                                  @map("area_hectares")
  // Soft delete — usunięcie pola NIE MOŻE kasować księgi polowej (treatments),
  // która jest obowiązkiem prawnym (Dz.U. 2022 poz. 2453, kontrola IJHARS).
  // deletedAt != null → pole ukryte w UI, ale zabiegi i historia zachowane.
  deletedAt    DateTime?                              @map("deleted_at")
  createdAt    DateTime                               @default(now()) @map("created_at")
  updatedAt    DateTime                               @updatedAt @map("updated_at")

  farm             Farm                  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  ndviReadings     NdviReading[]
  moistureReadings SoilMoistureReading[]
  recommendations  Recommendation[]
  treatments       Treatment[]
  scoutings        Scouting[]

  @@index([farmId])
  @@index([farmId, deletedAt])
  @@map("fields")
}

model NdviReading {
  id         String   @id @default(uuid())
  fieldId    String   @map("field_id")
  observedAt DateTime @map("observed_at")
  ndviMean   Float    @map("ndvi_mean")
  ndviMin    Float    @map("ndvi_min")
  ndviMax    Float    @map("ndvi_max")
  // Dodatkowe indeksy Sentinel-2 (wszystkie z jednego zapytania):
  // NDRE — niedobór azotu; NDWI — stres wodny; SAVI — skorygowany o glebę
  ndreMean   Float?   @map("ndre_mean")
  ndreMin    Float?   @map("ndre_min")
  ndreMax    Float?   @map("ndre_max")
  ndwiMean   Float?   @map("ndwi_mean")
  ndwiMin    Float?   @map("ndwi_min")
  ndwiMax    Float?   @map("ndwi_max")
  saviMean   Float?   @map("savi_mean")
  saviMin    Float?   @map("savi_min")
  saviMax    Float?   @map("savi_max")
  validCount Int      @default(0) @map("valid_count") // ile pikseli było walidnych
  cloudCover Float    @default(0) @map("cloud_cover")
  source     String   @default("sentinel-2")
  createdAt  DateTime @default(now()) @map("created_at")

  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([fieldId, observedAt])
  @@map("ndvi_readings")
}

model SoilMoistureReading {
  id          String   @id @default(uuid())
  fieldId     String   @map("field_id")
  observedAt  DateTime @map("observed_at")
  moisturePct Float    @map("moisture_pct")
  source      String   @default("smap")
  createdAt   DateTime @default(now()) @map("created_at")

  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([fieldId, observedAt])
  @@map("soil_moisture_readings")
}

model Recommendation {
  id              String    @id @default(uuid())
  fieldId         String    @map("field_id")
  severity        String // none, low, medium, high
  title           String
  message         String    @db.Text
  action          String    @db.Text
  sentViaWhatsapp Boolean   @default(false) @map("sent_via_whatsapp")
  sentAt          DateTime? @map("sent_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([fieldId, createdAt])
  @@map("recommendations")
}

// -----------------------------
// Księga polowa (e-rejestr zabiegów agrotechnicznych)
// OBOWIĄZEK PRAWNY PL/UE dla gospodarstw > 10 ha.
// Zgodnie z Dz.U. 2022 poz. 2453 i rozporządzeniami 2023-2025.
// IJHARS kontroluje, eksport do eWniosek Plus ARiMR.
// -----------------------------

model Treatment {
  id              String   @id @default(uuid())
  fieldId         String   @map("field_id")
  // WHEN
  performedAt     DateTime @map("performed_at")
  plannedAt       DateTime? @map("planned_at")
  // WHAT
  type            String // spray, fertilizer, sowing, harvest, tillage, irrigation, mowing, other
  purpose         String? // choroba, chwast, szkodnik, nawożenie, regulator wzrostu, inne
  // PRODUCT
  productName     String   @map("product_name")
  activeSubstance String?  @map("active_substance")
  registrationNo  String?  @map("registration_no")
  // DOSE
  doseValue       Float?   @map("dose_value")
  doseUnit        String?  @map("dose_unit") // l/ha, kg/ha, dt/ha
  areaTreated     Float    @map("area_treated")
  waterVolume     Float?   @map("water_volume")
  // WHO
  operatorName    String?  @map("operator_name")
  equipment       String?
  // CONDITIONS
  weatherTemp     Float?   @map("weather_temp")
  weatherWind     Float?   @map("weather_wind")
  weatherHumidity Float?   @map("weather_humidity")
  weatherNotes    String?  @map("weather_notes")
  // SAFETY
  preHarvestIntervalDays Int? @map("pre_harvest_interval_days")
  // META
  cost            Float?
  notes           String?  @db.Text
  source          String   @default("manual")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([fieldId, performedAt])
  @@index([type])
  @@map("treatments")
}

// -----------------------------
// Agent — KAŻDY rolnik dostaje własny agent, wzorzec clawlabspro
// Każdy Agent ma swój Hetzner VM z OpenClaw Gateway
// -----------------------------

model Agent {
  id              String    @id @default(uuid())
  farmId          String    @map("farm_id")
  name            String // "AgriClaw Advisor dla Gospodarstwa Kowalski"
  description     String?
  avatarUrl       String?   @map("avatar_url")
  model           String    @default("claude-sonnet-4-6") // AI model backend
  channel         String    @default("WEB") // WEB, WHATSAPP, TELEGRAM
  channelToken    String?   @map("channel_token")
  template        String    @default("agri-advisor") // always agri-advisor w AgriClaw
  // Hetzner provisioning (reuse z clawlabspro)
  hetznerServerId String?   @map("hetzner_server_id")
  cloudProvider   String?   @default("hetzner") @map("cloud_provider")
  cloudServerId   String?   @map("cloud_server_id")
  serverIp        String?   @map("server_ip")
  gatewayPort     Int       @default(18789) @map("gateway_port")
  gatewayToken    String?   @map("gateway_token")
  provisionToken  String?   @map("provision_token")
  status          String    @default("PROVISIONING") // PROVISIONING, READY, ERROR, DELETED
  lastHealthCheck DateTime? @map("last_health_check")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Markdown konfiguracja osobowości (wzorzec OpenClaw)
  soulMd      String? @map("soul_md") // rola + styl komunikacji
  identityMd  String? @map("identity_md") // "jestem doradcą rolnika X"
  heartbeatMd String? @map("heartbeat_md") // rytm codzienny
  toolsMd     String? @map("tools_md") // lista skilli agri-*
  bootstrapMd String? @map("bootstrap_md") // initial state
  userMd      String? @map("user_md") // kontekst gospodarstwa
  agentsMd    String? @map("agents_md") // sub-agenty

  // JSON-stringified configs
  automations     String? @default("[]")
  customScripts   String? @default("[]") @map("custom_scripts")
  channelConfig   String? @map("channel_config")
  integrationKeys String? @map("integration_keys")
  pendingConfig   String? @map("pending_config")

  farm            Farm             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  tasks           Task[]
  messages        Message[]
  events          Event[]
  installedSkills InstalledSkill[]
  conversations   Conversation[]

  @@index([farmId])
  @@index([status])
  @@map("agents")
}

model Task {
  id          String    @id @default(uuid())
  farmId      String    @map("farm_id")
  agentId     String?   @map("agent_id")
  status      String    @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  input       String    @db.Text
  output      String?   @db.Text
  error       String?   @db.Text
  tokensUsed  Int       @default(0) @map("tokens_used")
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  farm  Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  agent Agent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([farmId])
  @@index([agentId])
  @@map("tasks")
}

model InstalledSkill {
  id          String   @id @default(uuid())
  agentId     String   @map("agent_id")
  skillId     String   @map("skill_id") // agri-fields, agri-satellite, ...
  name        String
  version     String   @default("latest")
  installedAt DateTime @default(now()) @map("installed_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, skillId])
  @@map("installed_skills")
}

model Conversation {
  id         String   @id @default(uuid())
  farmId     String   @map("farm_id")
  agentId    String   @map("agent_id")
  sessionKey String   @unique @map("session_key") // OpenClaw session key
  title      String   @default("Nowa rozmowa")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  farm     Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  agent    Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([farmId])
  @@index([agentId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  agentId        String   @map("agent_id")
  conversationId String?  @map("conversation_id")
  role           String   @default("USER") // USER, ASSISTANT, TOOL
  content        String   @db.Text
  toolCalls      Json?    @map("tool_calls")
  metadata       String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  agent        Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@index([conversationId, createdAt])
  @@map("messages")
}

model Event {
  id        String   @id @default(uuid())
  farmId    String   @map("farm_id")
  agentId   String?  @map("agent_id")
  type      String // agent.deployed, ndvi.alert, whatsapp.sent, etc
  title     String
  detail    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  farm  Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  agent Agent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([farmId, createdAt])
  @@index([agentId])
  @@map("events")
}

model Usage {
  id                   String   @id @default(uuid())
  farmId               String   @map("farm_id")
  tasksCount           Int      @default(0) @map("tasks_count")
  tokensUsed           Int      @default(0) @map("tokens_used")
  promptTokensUsed     Int      @default(0) @map("prompt_tokens_used")
  completionTokensUsed Int      @default(0) @map("completion_tokens_used")
  periodStart          DateTime @map("period_start")
  periodEnd            DateTime @map("period_end")

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([farmId, periodStart])
  @@map("usage")
}

// -----------------------------
// Pool server (reuse z clawlabspro — shared pool dla pre-provisioned VMs)
// -----------------------------

model PoolServer {
  id              String    @id @default(uuid())
  planTier        String    @map("plan_tier") // free, standard, premium
  serverType      String    @map("server_type") // cx22, cx32...
  hetznerServerId String?   @map("hetzner_server_id")
  cloudProvider   String    @default("hetzner") @map("cloud_provider")
  cloudServerId   String?   @map("cloud_server_id")
  serverIp        String?   @map("server_ip")
  poolToken       String    @map("pool_token")
  status          String    @default("PROVISIONING") // PROVISIONING, READY, ASSIGNED
  assignedAgentId String?   @map("assigned_agent_id")
  lastPollAt      DateTime? @map("last_poll_at")
  errorMessage    String?   @map("error_message") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  readyAt         DateTime? @map("ready_at")

  @@index([status, planTier])
  @@map("pool_servers")
}

// Scouting — rolnik w polu robi zdjęcie, zaznacza pinezkę, notuje.
// GPS + foto (base64 MVP, potem Vercel Blob) + tag + severity + AI diagnoza.
model Scouting {
  id             String    @id @default(uuid())
  fieldId        String    @map("field_id")
  lat            Float
  lon            Float
  tag            String // disease, pest, frost, mechanical, weed, other
  severity       String    @default("medium") // low, medium, high
  note           String?   @db.Text
  photoUrl       String?   @db.Text @map("photo_url")
  aiDiagnosis    String?   @db.Text @map("ai_diagnosis")
  resolvedAt     DateTime? @map("resolved_at")
  resolvedAction String?   @db.Text @map("resolved_action")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([fieldId, createdAt])
  @@index([tag])
  @@map("scoutings")
}

// -----------------------------
// Rejestr ŚOR (MRiRW) — guardrail zaleceń agenta.
// Import z dane.gov.pl dataset 550 (CC0), wydania ~miesięczne.
// Jedyne prawnie wiążące źródło dopuszczeń; karencja TYLKO na etykiecie PDF.
// Research: docs/research/sor-mrirw-integracja-2026.md
// -----------------------------

model SorProduct {
  id         String    @id // id_sor GUID z rejestru, np. {E7C1EDCD-...}
  name       String // nazwa handlowa
  producer   String?
  permitNo   String?   @map("permit_no") // NrZezw
  kind       String? // Rodzaj: Herbicyd/Fungicyd/Insektycyd/Regulator wzrostu...
  substances String?   @db.Text // Zawartosc_SBCZ_prosty, np. "tebukonazol - 250 g"
  permitTo   DateTime? @map("permit_to") // TerminZezw — koniec zezwolenia
  saleTo     DateTime? @map("sale_to") // TerminDopSprzedazy — do kiedy sprzedaż
  useTo      DateTime? @map("use_to") // TerminDopuszczenia — do kiedy STOSOWANIE
  labelPage  String?   @map("label_page") // podstrona alfabetyczna gov.pl z etykietą PDF
  baseSor    String?   @map("base_sor") // produkt bazowy (handel równoległy)

  applications SorApplication[]

  @@index([name])
  @@map("sor_products")
}

model SorApplication {
  id       String  @id @default(uuid())
  sorId    String  @map("sor_id")
  crop     String // uprawa (tekst z rejestru, np. "pszenica ozima")
  pest     String? @db.Text // agrofag
  dose     String? @db.Text // tekst wolny: "Maksymalna dawka...: 0,65 l/ha"
  term     String? @db.Text // terminy/fazy BBCH — tekst wolny
  minorUse Boolean @default(false) @map("minor_use") // zastosowanie małoobszarowe
  methods  String? // metody stosowania

  product SorProduct @relation(fields: [sorId], references: [id], onDelete: Cascade)

  @@index([sorId])
  @@index([crop])
  @@map("sor_applications")
}

model SorImport {
  id                     String   @id @default(uuid())
  releaseLabel           String   @map("release_label") // np. "26.06.2026" z tytułu zasobu
  // Idempotencja po ID zasobów, nie dacie — korekta wydania z tą samą datą
  // dostaje na dane.gov.pl nowe id zasobów i MUSI zostać zaimportowana.
  basicResourceId        String   @map("basic_resource_id")
  applicationsResourceId String   @map("applications_resource_id")
  products               Int
  applications           Int
  importedAt             DateTime @default(now()) @map("imported_at")

  @@unique([basicResourceId, applicationsResourceId])
  @@index([importedAt])
  @@map("sor_imports")
}
