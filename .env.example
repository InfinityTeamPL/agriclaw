# ════════════════════════════════════════════════════════════════════════════
# AgriClaw — zmienne środowiskowe
# ════════════════════════════════════════════════════════════════════════════
# Skopiuj ten plik do `.env` i uzupełnij wartości. W produkcji ustaw w Vercel:
#   vercel env add NAZWA production
# albo przez dashboard: https://vercel.com/mysphere/agriclaw/settings/environment-variables
#
# Legenda:
#   [WYMAGANE]  — bez tego aplikacja nie zbuduje się / nie uruchomi
#   [KRYTYCZNE] — aplikacja startuje, ale kluczowa funkcjonalność padnie
#   [OPCJONALNE] — mamy fallback, można pominąć w MVP

# ── Database ──────────────────────────────────────────────────────────────
# Neon Postgres + PostGIS. W Vercelu auto-provisioning przez Marketplace:
#   vercel integration add neon
# W dev lokalnie: docker compose up -d + npm run db:seed
DATABASE_URL=""                # [WYMAGANE] postgresql://user:pass@host:5432/db
DATABASE_URL_UNPOOLED=""       # [WYMAGANE] ten sam string ale bez pgbouncer

# ── NextAuth ──────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=""             # [WYMAGANE] openssl rand -hex 32
NEXTAUTH_URL=""                # [WYMAGANE] https://agriclaw.vercel.app (prod) / http://localhost:3000 (dev)
GOOGLE_CLIENT_ID=""            # [OPCJONALNE] bez → Google button się ukrywa
GOOGLE_CLIENT_SECRET=""        # [OPCJONALNE]

# ── Copernicus Data Space Ecosystem (Sentinel-1 + Sentinel-2) ────────────
# Rejestracja darmowa: https://dataspace.copernicus.eu → User dashboard → OAuth clients → Create
# Limit: 30 000 zapytań / miesiąc free tier
CDSE_CLIENT_ID=""              # [KRYTYCZNE] bez → mock NDVI w dev, błąd w prod
CDSE_CLIENT_SECRET=""          # [KRYTYCZNE]

# ── OpenRouter (Gemma 4 + fallback chain dla diagnozy z kamery) ──────────
# https://openrouter.ai/keys — darmowe modele + płatne backup
OPENROUTER_API_KEY=""          # [KRYTYCZNE] bez → /dashboard/diagnose nie działa

# ── Cron auth ─────────────────────────────────────────────────────────────
CRON_SECRET=""                 # [WYMAGANE] openssl rand -hex 32 (zabezpiecza /api/cron/*)

# ── OpenClaw agent skill token (agent → /api/skills/agri-*) ──────────────
OPENCLAW_SKILL_TOKEN=""        # [OPCJONALNE] openssl rand -hex 32

# ── Admin ─────────────────────────────────────────────────────────────────
ADMIN_EMAILS="contact@infinityteam.io"    # [WYMAGANE] lista oddzielona przecinkiem

# ── Hetzner (provisioning agentów per-gospodarstwo, Faza 4) ───────────────
# W dev bez tych envów agent jest mockowany (ready po 3s na 127.0.0.1).
# Produkcyjnie: https://console.hetzner.cloud → Security → API Tokens + SSH Keys
HETZNER_API_TOKEN=""           # [OPCJONALNE] Faza 4
HETZNER_SSH_KEY_ID=""          # [OPCJONALNE]
HETZNER_SNAPSHOT_ID=""         # [OPCJONALNE] ID snapshota z Docker+OpenClaw pre-installed
HETZNER_SSH_PRIVATE_KEY=""     # [OPCJONALNE] Base64 Ed25519 private key

# ── AI keys dostarczane do user agents (Faza 4) ──────────────────────────
PLATFORM_OPENAI_KEY=""         # [OPCJONALNE]
PLATFORM_ANTHROPIC_KEY=""      # [OPCJONALNE]
PLATFORM_GOOGLE_AI_KEY=""      # [OPCJONALNE]

# ── NASA Earthdata (SMAP wilgotność gleby) ───────────────────────────────
# Rejestracja: https://urs.earthdata.nasa.gov
# SMAP ma tylko 9 km rozdzielczości — Open-Meteo soil_moisture jest lepszy dla PL.
EARTHDATA_USERNAME=""          # [OPCJONALNE] mamy Open-Meteo fallback
EARTHDATA_PASSWORD=""          # [OPCJONALNE]

# ── Upstash Redis (rate limiting) ─────────────────────────────────────────
# https://upstash.com → free tier 10k req/dzień
# Bez tego → in-memory fallback (działa ale bez cross-instance sync)
UPSTASH_REDIS_REST_URL=""      # [OPCJONALNE]
UPSTASH_REDIS_REST_TOKEN=""    # [OPCJONALNE]

# ── WhatsApp Business Cloud (Faza 5 — alerty i chat) ─────────────────────
# https://developers.facebook.com → Meta Business → WhatsApp API
WHATSAPP_TOKEN=""              # [OPCJONALNE] Faza 5
WHATSAPP_PHONE_ID=""           # [OPCJONALNE]
WHATSAPP_VERIFY_TOKEN=""       # [OPCJONALNE] webhook verification
